{
  "name": "ndk-language-support",
  "displayName": "Ndk Language Support",
  "description": "Syntax highlighting and language support for the NDK programming language.",
  "icon": "ndk-icon.png",
  "license": "MIT",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ndk123-web/ndk-interpreter/ndk-language-support"
  },
  "homepage": "https://github.com/ndk123-web/ndk-language-support",
  "publisher": "ndkdev",
  "type": "module",
  "allowImportingTsExtensions": true,
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ndk",
        "aliases": [
          "Ndk",
          "ndk"
        ],
        "extensions": [
          ".ndk"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ndk",
        "scopeName": "source.ndk",
        "path": "./syntaxes/ndk.tmLanguage.json"
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "typescript": "^7.0.2"
  }
}
